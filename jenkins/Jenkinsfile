pipeline {
    agent any

    environment {
        // Correct way to handle Login Server (as a string or Secret Text)
        REGISTRY_LOGIN_SERVER = "devsecopsacr28032026.azurecr.io" 
        
        // This helper automatically creates REGISTRY_USR and REGISTRY_PSW
        REGISTRY = credentials('acr-credentials-id') 
        
        // Initialize as empty; we will populate these in the Checkout stage
        GIT_COMMIT_SHORT = ""
        IMAGE_TAG = ""
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    // Populate Git variables AFTER checkout
                    GIT_COMMIT_SHORT = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                    IMAGE_TAG = "${env.BUILD_NUMBER}-${GIT_COMMIT_SHORT}"
                    echo "Starting build for tag: ${IMAGE_TAG}"
                }
            }
        }

        stage('Build Microservices') {
            parallel {
                stage('Build User Service') {
                    steps {
                        // Using double quotes (""") to allow variable interpolation
                        sh """
                            cd microservices/user-service
                            docker build -t ${REGISTRY_LOGIN_SERVER}/user-service:${IMAGE_TAG} .
                            docker build -t ${REGISTRY_LOGIN_SERVER}/user-service:latest .
                        """
                    }
                }
                stage('Build product Service') {
                    steps {
                        // Using double quotes (""") to allow variable interpolation
                        sh """
                            cd microservices/product-service
                            docker build -t ${REGISTRY_LOGIN_SERVER}/product-service:${IMAGE_TAG} .
                            docker build -t ${REGISTRY_LOGIN_SERVER}/product-service:latest .
                        """
                    }
                }
                stage('Build order Service') {
                    steps {
                        // Using double quotes (""") to allow variable interpolation
                        sh """
                            cd microservices/order-service
                            docker build -t ${REGISTRY_LOGIN_SERVER}/order-service:${IMAGE_TAG} .
                            docker build -t ${REGISTRY_LOGIN_SERVER}/order-service:latest .
                        """
                    }
                }
                // ... Apply same double-quote change to Order and Product services ...
            }
        }

        stage('Push to ACR') {
            steps {
                script {
                    // Use REGISTRY_PSW and REGISTRY_USR provided by credentials helper
                    sh """
                        echo ${REGISTRY_PSW} | docker login ${REGISTRY_LOGIN_SERVER} -u ${REGISTRY_USR} --password-stdin
                        docker push ${REGISTRY_LOGIN_SERVER}/user-service:${IMAGE_TAG}
                        docker push ${REGISTRY_LOGIN_SERVER}/user-service:latest
                        docker push ${REGISTRY_LOGIN_SERVER}/product-service:${IMAGE_TAG}
                        docker push ${REGISTRY_LOGIN_SERVER}/product-service:latest
                        docker push ${REGISTRY_LOGIN_SERVER}/order-service:${IMAGE_TAG}
                        docker push ${REGISTRY_LOGIN_SERVER}/order-service:latest
                        # ... add other services ...
                    """
                }
            }
        }

        stage('Update K8s Manifests') {
            steps {
                sh """
                    sed -i "s|image:.*user-service.*|image: ${REGISTRY_LOGIN_SERVER}/user-service:${IMAGE_TAG}|g" k8s-manifests/user-service.yaml
                    sed -i "s|image:.*product-service.*|image: ${REGISTRY_LOGIN_SERVER}/product-service:${IMAGE_TAG}|g" k8s-manifests/user-service.yaml
                    sed -i "s|image:.*order-service.*|image: ${REGISTRY_LOGIN_SERVER}/order-service:${IMAGE_TAG}|g" k8s-manifests/user-service.yaml
                    # ... add other services ...
                """
            }
        }

    stage('Deploy via Argo CD') {
    steps {
        // Requires the 'SSH Agent' plugin
        sshagent(['github-ssh-key']) {
            sh """
                git config user.email "baba.linux27@gmail.com"
                git config user.name "BabaFakruddin40"
                
                # Ensure the remote is set to SSH, not HTTPS
                git remote set-url origin git@github.com:BabaFakruddin40/devsecops-azure-cicd.git
                
                git add k8s-manifests/
                git commit -m "Update images: Build ${env.BUILD_NUMBER}" || true
                
                # SSH Agent automatically handles the key handshake
                git push origin HEAD:main
            """
        }
    }
}

    post {
        always { cleanWs() }
    }
}